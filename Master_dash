<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>TireDash NYC | Command Center</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800;900&display=swap');
        body { font-family: 'Inter', sans-serif; -webkit-tap-highlight-color: transparent; }
        .status-pulse { animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite; }
        @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: .5; } }
    </style>
</head>
<body class="bg-slate-50 text-slate-900">
    <div class="min-h-screen flex flex-col md:flex-row">
        
        <!-- Sidebar (Desktop) -->
        <aside class="hidden md:flex flex-col w-72 bg-slate-900 text-white p-8 h-screen sticky top-0">
            <div class="flex items-center space-x-3 mb-12">
                <div class="bg-orange-600 p-2 rounded-xl shadow-lg shadow-orange-900/40">
                    <i data-lucide="truck" class="text-white" stroke-width="3"></i>
                </div>
                <span class="text-2xl font-black italic tracking-tighter uppercase">TIREDASH <span class="text-orange-500 NOT-italic">NYC</span></span>
            </div>
            <nav class="flex-1 space-y-2">
                <div class="flex items-center space-x-3 p-4 bg-orange-600 rounded-2xl font-bold shadow-xl shadow-orange-600/20">
                    <i data-lucide="navigation" size="20"></i>
                    <span>Dispatch Board</span>
                </div>
                <div class="flex items-center space-x-3 p-4 text-slate-400 font-bold">
                    <i data-lucide="users" size="20"></i>
                    <span>Fleet Drivers</span>
                </div>
            </nav>
        </aside>

        <!-- Mobile View Header -->
        <div class="md:hidden bg-white p-5 border-b border-slate-200 sticky top-0 z-[100] flex justify-between items-center">
            <div class="flex items-center space-x-2">
                <i data-lucide="truck" class="text-orange-600" stroke-width="3"></i>
                <span class="text-2xl font-black italic tracking-tighter uppercase">TIREDASH <span class="text-orange-600 NOT-italic">NYC</span></span>
            </div>
            <i data-lucide="menu" class="text-slate-900"></i>
        </div>

        <!-- Main Workspace -->
        <main class="flex-1 p-5 md:p-12 max-w-7xl mx-auto w-full pb-24 md:pb-12">
            <header class="flex flex-col md:flex-row justify-between items-start md:items-end mb-10 gap-6">
                <div>
                    <div class="inline-flex items-center space-x-2 bg-orange-50 text-orange-700 px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest mb-3">
                        <span class="w-1.5 h-1.5 bg-orange-600 rounded-full status-pulse"></span>
                        <span>Live System Active</span>
                    </div>
                    <h1 class="text-4xl font-black tracking-tight text-slate-900">Fleet Dispatch</h1>
                    <p class="text-slate-500 font-semibold mt-1">Real-time roadside response management.</p>
                </div>
                <button class="w-full md:w-auto bg-slate-900 text-white px-8 py-4 rounded-2xl font-black shadow-2xl shadow-slate-300 active:scale-95 flex items-center justify-center space-x-3">
                    <i data-lucide="plus-circle" size="20" stroke-width="3"></i>
                    <span>CREATE DISPATCH</span>
                </button>
            </header>

            <!-- KPI Dashboard -->
            <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-10">
                <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Active Calls</p>
                    <p class="text-3xl font-black text-slate-900">09</p>
                </div>
                <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm border-l-4 border-l-orange-500">
                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Avg Response</p>
                    <p class="text-3xl font-black text-slate-900">19m</p>
                </div>
                <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Idle Trucks</p>
                    <p class="text-3xl font-black text-slate-900">04</p>
                </div>
                <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Today Revenue</p>
                    <p class="text-3xl font-black text-emerald-600">$4.8k</p>
                </div>
            </div>

            <!-- Dispatch Feed -->
            <div class="space-y-4">
                <div class="bg-white p-6 rounded-[2.5rem] border border-slate-100 shadow-sm flex flex-col md:flex-row justify-between items-start md:items-center relative overflow-hidden hover:border-orange-200 transition-all">
                    <div class="flex items-start space-x-5">
                        <div class="bg-orange-50 p-5 rounded-3xl text-orange-600">
                            <i data-lucide="wrench" size="28"></i>
                        </div>
                        <div>
                            <h3 class="font-black text-xl text-slate-900">Global Logistics Corp</h3>
                            <div class="flex flex-wrap items-center text-sm font-bold text-slate-400 space-x-5 mt-1">
                                <span class="flex items-center text-orange-600"><i data-lucide="map-pin" size="14" class="mr-1.5"></i>Midtown, NY</span>
                                <span>Flat Tire Change</span>
                            </div>
                        </div>
                    </div>
                    <div class="w-full md:w-auto mt-6 md:mt-0 flex justify-between md:flex-col items-center md:items-end">
                        <span class="px-3 py-1 bg-blue-100 text-blue-700 rounded-full text-[10px] font-black uppercase tracking-tighter">En Route</span>
                        <p class="text-xs font-bold text-slate-400 md:mt-2">Mike S.</p>
                    </div>
                </div>
            </div>
        </main>
    </div>
    <script>lucide.createIcons();</script>
</body>
</html>
